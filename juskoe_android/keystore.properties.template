# Copy to `keystore.properties` (gitignored) for signed release builds.
# Generate a keystore once:
#   keytool -genkey -v -keystore juskoe-release.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias juskoe
# Then register the keystore's SHA-1 on the Android OAuth client in Google Cloud.

storeFile=juskoe-release.jks
storePassword=
keyAlias=juskoe
keyPassword=
