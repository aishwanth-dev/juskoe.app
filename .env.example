# ══════════════════════════════════════════
# JUSKOE — Environment Variables
# Copy this to .env and fill in your values
# ══════════════════════════════════════════

# === Supabase ===
SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_URL=https://your_project_ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_ACCESS_TOKEN=your_personal_access_token

# === OpenRouter (AI fallback for desktop) ===
# Comma-separated list of API keys (failover order)
OPENROUTER_KEYS=your-openrouter-key-1,your-openrouter-key-2,your-openrouter-key-3

# === Gemini (primary AI for both desktop and android) ===
GEMINI_API_KEY=your_gemini_api_key

# === Google OAuth ===
GOOGLE_WEB_CLIENT_ID=your_google_web_client_id
GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id

# === Razorpay (payments) ===
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
