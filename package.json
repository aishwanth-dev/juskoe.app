{
  "name": "juskoe",
  "version": "1.0.0",
  "description": "AI Voice Assistant - Just speak, it happens",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "electron": "electron .",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "author": "Juskoe",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.0",
    "pg": "^8.20.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.95.3",
    "active-win": "^8.2.1",
    "ffmpeg-static": "^5.3.0",
    "razorpay": "^2.9.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "sherpa-onnx-node": "^1.12.25"
  },
  "build": {
    "appId": "com.juskoe.app",
    "productName": "Juskoe",
    "copyright": "Copyright © 2026 Juskoe",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "!node_modules/**/README*",
      "!node_modules/**/CHANGELOG*",
      "!node_modules/**/test/**",
      "!node_modules/**/docs/**",
      "!node_modules/**/*.md"
    ],
    "asarUnpack": [
      "node_modules/sherpa-onnx-node/**/*",
      "node_modules/active-win/**/*",
      "node_modules/ffmpeg-static/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/sherpa-onnx-whisper-base",
        "to": "assets/sherpa-onnx-whisper-base",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "assets/juskoe_logo.png",
        "to": "assets/juskoe_logo.png"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/juskoe_logo.png",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Juskoe",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/juskoe_logo.png",
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "title": "Juskoe",
      "internetEnabled": true
    }
  }
}
